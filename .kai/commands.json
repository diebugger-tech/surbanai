{
  "uptime": {
    "cmd": "uptime",
    "risiko": "low",
    "beschreibung": "Systemlaufzeit und Auslastung anzeigen",
    "sandbox": true
  },
  "disk-usage": {
    "cmd": "df -h /",
    "risiko": "low",
    "beschreibung": "Speicherplatzbelegung der Root-Partition anzeigen",
    "sandbox": true
  },
  "git-status": {
    "cmd": "git status",
    "risiko": "low",
    "beschreibung": "Git Status des lokalen KAiOSS-Repositories",
    "sandbox": true
  },
  "git-diff": {
    "cmd": "git diff",
    "risiko": "low",
    "beschreibung": "Git Diff des lokalen KAiOSS-Repositories",
    "sandbox": true
  },
  "git-log": {
    "cmd": "git log -n 5 --oneline",
    "risiko": "low",
    "beschreibung": "Die letzten 5 Commits im KAiOSS-Repository anzeigen",
    "sandbox": true
  },
  "surreal-backup": {
    "cmd": "surreal export --conn ws://localhost:8000 --user root --pass root --ns kaioss --db kaioss",
    "risiko": "medium",
    "beschreibung": "SurrealDB kaioss-Datenbank exportieren",
    "sandbox": false
  },
  "ollama-list": {
    "cmd": "ollama list",
    "risiko": "low",
    "beschreibung": "Installierte Ollama-Modelle auflisten",
    "sandbox": false
  },
  "system-journal": {
    "cmd": "journalctl -n 50 --no-pager",
    "risiko": "low",
    "beschreibung": "Letzte 50 Systemlog-Einträge ausgeben",
    "sandbox": false
  },
  "sync-projects": {
    "cmd": "bash scripts/sync-projects.sh",
    "risiko": "low",
    "beschreibung": "Projekte aus Unterverzeichnissen in SurrealDB importieren",
    "sandbox": false
  }
}
